rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Shipments: readable by anyone (for public tracking),
    // writable only from authenticated sessions or the admin panel.
    // For now, open write for the admin panel until auth is added.
    match /shipments/{shipmentId} {
      allow read: if true;
      allow write: if true;
    }

    // Counter for tracking code generation
    match /meta/{docId} {
      allow read, write: if true;
    }
  }
}
